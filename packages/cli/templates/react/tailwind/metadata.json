{
  "name": "tailwind",
  "order": 3,
  "enabledWhen": "tailwind",
  "devDependencies": {
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0"
  },
  "vite": {
    "imports": ["import tailwindcss from \"@tailwindcss/vite\";"],
    "prependPlugins": ["tailwindcss()"],
    "usePathAlias": true
  },
  "entryHydration": {
    "imports": {
      "spa": ["import \"./index.css\";"],
      "router-v7": ["import \"@/app/index.css\";"]
    }
  }
}