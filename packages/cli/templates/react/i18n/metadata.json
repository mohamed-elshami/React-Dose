{
  "name": "i18n",
  "order": 2,
  "enabledWhen": "i18n",
  "dependencies": {
    "i18next": "^26.0.0",
    "react-i18next": "^17.0.0"
  },
  "providerWrapper": {
    "imports": [
      "import { I18nextProvider } from \"react-i18next\";",
      "import i18n from \"@/i18n\";"
    ],
    "component": "<I18nextProvider i18n={i18n}>"
  },
  "entryHydration": {
    "imports": {
      "spa": ["import \"@/i18n\";"],
      "router-v7": ["import \"@/i18n\";"]
    }
  },
  "vite": {
    "usePathAlias": true
  }
}